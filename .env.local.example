# ============================================================
# FormaCRM — Variables d'environnement
# ============================================================
# Copiez ce fichier en .env.local et renseignez les valeurs
# cp .env.local.example .env.local
# ============================================================

# ─── Supabase ───
# Dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://VOTRE-PROJET.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Application ───
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=FormaCRM

# ─── Resend (emails transactionnels) ───
# https://resend.com/api-keys
# En dev, les emails sont loggés en console si cette clé est absente
RESEND_API_KEY=

# ─── Stripe (facturation en ligne) — Phase 2 ───
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
